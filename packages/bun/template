# Template file for 'bun'
pkgname=bun
version=1.3.13
revision=1
archs="x86_64 aarch64 x86_64-musl aarch64-musl"
hostmakedepends="unzip"
create_wrksrc=yes
short_desc="Incredibly fast JavaScript runtime, bundler, test runner, and package manager"
maintainer="Evan Alvarez <evanalvarez@tutamail.com>"
license="MIT"
homepage="https://bun.sh"
nostrip=yes
nopie=yes
nodebug=yes
ignore_elf_files="usr/bin/bun"

case "$XBPS_TARGET_MACHINE" in
x86_64)
    distfiles="https://github.com/oven-sh/bun/releases/download/bun-v${version}/bun-linux-x64.zip"
    checksum=79c0771fa8b92c33aae41e15a0e0d307ea99d0e2f00317c71c6c53237a78e25a
    _arch_dir="bun-linux-x64"
    ;;
aarch64)
    distfiles="https://github.com/oven-sh/bun/releases/download/bun-v${version}/bun-linux-aarch64.zip"
    checksum=70bae41b3908b0a120e1e58c5c8af30e74afae3b8d11b0d3fdd8e787ddfb4b22
    _arch_dir="bun-linux-aarch64"
    ;;
x86_64-musl)
    distfiles="https://github.com/oven-sh/bun/releases/download/bun-v${version}/bun-linux-x64-musl.zip"
    checksum=5b91a48f0b00df9fd2da8bff1a795d2659d842da966432969203f25da19d1c74
    _arch_dir="bun-linux-x64-musl"
    ;;
aarch64-musl)
    distfiles="https://github.com/oven-sh/bun/releases/download/bun-v${version}/bun-linux-aarch64-musl.zip"
    checksum=5385e978107ce4934298d8d6afe9bfbb898683f6cc23e6753a0da60bc60c5b81
    _arch_dir="bun-linux-aarch64-musl"
    ;;
esac

do_extract() {
    mkdir -p ${wrksrc}
    unzip -q -o ${XBPS_SRCDISTDIR}/${pkgname}-${version}/${distfiles##*/} -d ${wrksrc}
}

do_install() {
    vbin ${_arch_dir}/bun bun
    ln -s /usr/bin/bun ${DESTDIR}/usr/bin/bunx
}
