post_extract() {
    if [ -d "${XBPS_BUILDDIR}/xdg-ninja-${_gitrev}" ]; then
        mv "${XBPS_BUILDDIR}/xdg-ninja-${_gitrev}" "${wrksrc}"
    fi
}

do_install() {
    make DESTDIR="${DESTDIR}" PREFIX="/usr" install

    vlicense LICENSE
}
