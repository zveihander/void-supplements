# Template file for 'zen-browser'
pkgname=zen-browser
version=1.19.11b
revision=1
archs="x86_64 aarch64"
hostmakedepends="tar xz"
depends="desktop-file-utils hicolor-icon-theme nss nspr pciutils"
short_desc="Welcome to a calmer internet"
maintainer="evanalvarez@tutamail.com"
license="MPL-2.0"
homepage="https://www.zen-browser.app/"
changelog="https://github.com/zen-browser/desktop/releases"
nostrip=yes

case "$XBPS_TARGET_MACHINE" in
x86_64*)
    _upstream_arch="x86_64"
    checksum=65df3ffeb31f8046aca55ad70d6cf0c5130c25b1e8e470a047e5732b98137f19
    ;;
aarch64*)
    _upstream_arch="aarch64"
    checksum=d6367dfc66449c7defa758502f9f5709982254ad5a5d88b9a9f46f26a46177bf
    ;;
esac

distfiles="https://github.com/zen-browser/desktop/releases/download/${version}/zen.linux-${_upstream_arch}.tar.xz"

do_install() {
    vmkdir usr/bin
    vmkdir "usr/lib/${pkgname}"

    vcopy "." "usr/lib/${pkgname}"

    ln -sf "/usr/lib/${pkgname}/zen" "${DESTDIR}/usr/bin/zen"

    vinstall "${FILESDIR}/zen.desktop" 0644 usr/share/applications/

    vmkdir "usr/lib/${pkgname}/distribution"
    vinstall "${FILESDIR}/policies.json" 0644 "usr/lib/${pkgname}/distribution"

    for size in 16 32 48 64 128; do
        vinstall "browser/chrome/icons/default/default${size}.png" 0644 \
            "usr/share/icons/hicolor/${size}x${size}/apps" "zen.png"
    done

    ln -sf /usr/share/hunspell "${DESTDIR}/usr/lib/${pkgname}/dictionaries"
    ln -sf /usr/share/hyphen "${DESTDIR}/usr/lib/${pkgname}/hyphenation"
    ln -sf /usr/lib/libnssckbi.so "${DESTDIR}/usr/lib/${pkgname}/libnssckbi.so"
}
