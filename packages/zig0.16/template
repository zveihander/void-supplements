do_install() {
    vmkdir usr/lib/zig
    vcopy lib usr/lib/zig

    vinstall zig 755 usr/lib/zig

    cat >zig.sh <<-EOF
#!/bin/sh
exec /usr/lib/zig/zig "\$@"
EOF
    vbin zig.sh zig

    vlicense LICENSE
}
